{
  "$schema": "https://raw.githubusercontent.com/nicknisi/tauri-v2-todos/refs/heads/main/src-tauri/gen/schemas/desktop-schema.json",
  "productName": "Chatter",
  "mainBinaryName": "Chatter",
  "version": "0.1.1",
  "identifier": "org.talkbank.chatter",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Chatter",
        "width": 1000,
        "height": 700,
        "minWidth": 700,
        "minHeight": 500
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEE1NDhBQzA4QzcyNTU3OTUKUldTVlZ5WEhDS3hJcGZhdUhsZkdOOW5DTFBabkJ6dXZBc1JsWmJVTmNWOEVoUWVFME5USWszaGgK",
      "endpoints": [
        "https://github.com/TalkBank/chatter/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": "all",
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  }
}
